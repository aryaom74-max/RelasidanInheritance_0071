#include <iostream>
#include <string>

using namespace std;

class orang {
public:
    string nama;

    // Constructor parent
    orang(string pNama) : nama(pNama) {
        cout << "orang dibuat" << endl;
    }
    
    // Virtual Destructor (Sangat disarankan dalam inheritance)
    virtual ~orang() {
        cout << "orang dihapus" << endl;
    }

    int jumlah(int a, int b) {
        return a + b;
    }
};

class pelajar : public orang {
public:
    string sekolah;

    // Inisialisasi constructor parent dan member sendiri
    pelajar(string pNama, string pSekolah) : orang(pNama), sekolah(pSekolah) {
        cout << "pelajar dibuat" << endl;
    }

    ~pelajar() {
        cout << "pelajar dihapus" << endl;
    }

    string perkenalan() {
        return "Hallo, nama saya " + nama + " dari sekolah " + sekolah + "\n";
    }
};

int main() {
    // Membuat objek di stack
    pelajar siswa1("andi laksono", "SMAN 1 Bantul");
    
    cout << siswa1.perkenalan();
    cout << "Hasil = " << siswa1.jumlah(10, 90) << endl;

    return 0;
}
